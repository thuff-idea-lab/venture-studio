{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@studio/*": ["studio/*"],
      "@lib/*": ["studio/lib/*"]
    }
  },
  "include": ["studio/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "apps"]
}
