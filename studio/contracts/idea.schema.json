{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IdeaRecord",
  "type": "object",
  "required": ["title", "audience", "pain", "workaround", "productPossibilities", "monetization", "confidence", "signalCount", "sourceCluster"],
  "properties": {
    "title": { "type": "string", "description": "Short opportunity name" },
    "audience": { "type": "string", "description": "Who has this problem" },
    "pain": { "type": "string", "description": "The specific recurring pain or friction" },
    "workaround": { "type": "string", "description": "What they currently do instead" },
    "productPossibilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Possible product types (SaaS, directory, chrome extension, etc.)"
    },
    "monetization": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Plausible monetization paths"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "LLM confidence in this being a real opportunity"
    },
    "signalCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of independent sources that surfaced this pain"
    },
    "sourceCluster": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "url"],
        "properties": {
          "platform": { "type": "string" },
          "url": { "type": "string" },
          "context": { "type": "string" }
        }
      }
    },
    "summary": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": { "type": "string", "enum": ["link", "metric", "quote"] },
          "value": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "url"],
        "properties": {
          "platform": { "type": "string" },
          "url": { "type": "string" },
          "context": { "type": "string" }
        }
      }
    },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "assetTypeHint": {
      "type": "string",
      "enum": ["website", "directory", "saas", "youtube", "newsletter", "bot", "data", "unknown"]
    }
  }
}
