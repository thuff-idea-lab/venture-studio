{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IdeaRecord",
  "type": "object",
  "required": ["title", "summary", "sources", "keywords", "tags", "assetTypeHint"],
  "properties": {
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": { "type": "string", "enum": ["link", "metric", "quote"] },
          "value": { "type": "string" }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform", "url"],
        "properties": {
          "platform": { "type": "string" },
          "url": { "type": "string" },
          "context": { "type": "string" }
        }
      }
    },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
    "assetTypeHint": {
      "type": "string",
      "enum": ["website", "directory", "saas", "youtube", "newsletter", "bot", "data", "unknown"]
    }
  }
}
