{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProjectRecord",
  "type": "object",
  "required": ["slug", "projectType", "oneSentencePitch", "targetUser", "primaryMonetization", "mvpDefinition", "buildPlan", "testPlan"],
  "properties": {
    "slug": { "type": "string" },
    "projectType": {
      "type": "string",
      "enum": ["website", "directory", "saas", "youtube", "newsletter", "bot", "data"]
    },
    "oneSentencePitch": { "type": "string" },
    "targetUser": { "type": "string" },
    "primaryMonetization": {
      "type": "array",
      "items": { "type": "string", "enum": ["ads", "affiliate", "leadgen", "subscription", "product", "data"] }
    },
    "mvpDefinition": {
      "type": "object",
      "properties": {
        "deliverables": { "type": "array", "items": { "type": "string" } },
        "timeboxHours": { "type": "number" },
        "successMetric": { "type": "string" }
      }
    },
    "buildPlan": {
      "type": "object",
      "properties": {
        "steps": { "type": "array", "items": { "type": "string" } },
        "tech": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "testPlan": {
      "type": "object",
      "properties": {
        "channels": { "type": "array", "items": { "type": "string" } },
        "budget": { "type": "number" },
        "goNoGo": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
