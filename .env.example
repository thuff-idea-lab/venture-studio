# ─── AI ────────────────────────────────────────────────
# GitHub Models API (free with GitHub Copilot)
# Get token: github.com → Settings → Developer Settings → Fine-grained tokens
# Required permission: Models → Read
LLM_PROVIDER=github
GITHUB_TOKEN=your_github_pat_here

# ─── Database ──────────────────────────────────────────
# Supabase (free tier) — supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_key_here
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres

# ─── Scraping (add later) ──────────────────────────────
FIRECRAWL_API_KEY=your_key_here
SERP_API_KEY=your_key_here

# ─── Email (add when first project launches) ───────────
RESEND_API_KEY=your_key_here

# ─── Analytics (add when first project launches) ───────
POSTHOG_KEY=your_key_here

# ─── Distribution (add in Phase 2) ────────────────────
BUFFER_ACCESS_TOKEN=your_key_here
PRODUCT_HUNT_API_TOKEN=your_key_here
BEEHIIV_API_KEY=your_key_here
