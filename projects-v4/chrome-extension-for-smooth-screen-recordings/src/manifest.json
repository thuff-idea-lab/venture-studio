{
  "manifest_version": 3,
  "name": "SmoothScreen Recorder",
  "version": "1.0.0",
  "description": "Effortless Screen Recordings with Natural Enhancements — automatically applies smooth cursor animations and natural zooms to your screen recordings.",
  "permissions": [
    "desktopCapture",
    "downloads",
    "storage",
    "activeTab",
    "tabs",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
